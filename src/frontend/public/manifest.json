{
  "name": "Weighted SWOT Decision Studio",
  "short_name": "SWOT Studio",
  "description": "Weighted SWOT + MCDA Decision analysis tool",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#1e3a5f",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/x-swot-project": [".swot"]
      },
      "launch_type": "single-client"
    }
  ]
}
